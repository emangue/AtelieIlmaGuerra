# ========================================
# ATELIÊ ILMA GUERRA - Backend
# Copie para .env e preencha os valores
# NUNCA commitar .env no Git
# ========================================

APP_NAME="Ateliê Ilma Guerra - API"
APP_VERSION="1.0.0"
DEBUG=false

# Database - SQLite (dev) ou PostgreSQL (prod)
# Dev: deixe DATABASE_URL vazio; usa DATABASE_PATH
DATABASE_PATH=./database/atelie.db
# Prod: use DATABASE_URL (sobrescreve DATABASE_PATH)
# DATABASE_URL=postgresql://atelie_user:SENHA@127.0.0.1:5432/atelie_db

# CORS - domínios permitidos (separados por vírgula)
BACKEND_CORS_ORIGINS="https://gestao.atelieilmaguerra.com.br,http://localhost:3000"

HOST=127.0.0.1
PORT=8000

# JWT - OBRIGATÓRIO em produção (gerar: openssl rand -hex 32)
JWT_SECRET_KEY=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
